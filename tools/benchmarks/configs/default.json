{
  "build_configs": [
    {
      "name": "default",
      "env": {},
      "makevars": {}
    },
    {
      "name": "o3_native_no_simd",
      "env": {
        "RAYRENDER_DISABLE_SIMD": "true"
      },
      "makevars": {
        "CXX17FLAGS": "-O3 -march=native",
        "CXX14FLAGS": "-O3 -march=native",
        "CXXFLAGS": "-O3 -march=native"
      }
    },
    {
      "name": "o3_native_simd_sse",
      "env": {},
      "makevars": {
        "CXX17FLAGS": "-O3 -march=native -DRAYSIMD -DHAS_SSE",
        "CXX14FLAGS": "-O3 -march=native -DRAYSIMD -DHAS_SSE",
        "CXXFLAGS": "-O3 -march=native -DRAYSIMD -DHAS_SSE"
      }
    }
  ],
  "benchmark_defaults": {
    "width": 50,
    "height": 50,
    "samples": 32,
    "seed": 1,
    "threads": 1,
    "time_build": false,
    "write_artifact": false,
    "sphere_count": 3000,
    "object_count": 3000
  }
}
